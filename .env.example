# ── Database
DATABASE_URL=postgresql://aigcm:password@localhost:5432/aigcm
CLICKHOUSE_URL=http://localhost:8123
REDIS_URL=redis://localhost:6379

# ── Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_USAGE_TOPIC=usage-events
KAFKA_ALERT_TOPIC=alert-events

# ── Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=3600

# ── Encryption (Key Vault)
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789:key/...
VAULT_ENCRYPTION_KEY=your-aes-256-key-base64

# ── AI Providers (managed via key vault in prod)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://....openai.azure.com

# ── Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
SENDGRID_API_KEY=SG....

# ── AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_AUDIT_BUCKET=ai-gcm-audit-logs
